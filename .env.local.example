# MyWeather - server environment variables
# Copy this file to .env.local and fill only the keys you need.

# Official meteorology
AEMET_API_KEY=

# Personal weather stations
WEATHER_UNDERGROUND_API_KEY=

# AETHER AI
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=

# Additional providers
TOMORROW_API_KEY=
OPENWEATHERMAP_API_KEY=

# EUMETSAT satellite WMS (MSG/MTG layers)
EUMETSAT_CONSUMER_KEY=
EUMETSAT_CONSUMER_SECRET=

# Optional lightning layer
BLITZORTUNG_TOKEN=
