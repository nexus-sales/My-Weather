# Solajero - server environment variables
# Copy this file to .env.local and fill only the keys you need.

# Official meteorology
AEMET_API_KEY=

# Personal weather stations
WEATHER_UNDERGROUND_API_KEY=

# AETHER AI
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=

# Additional providers
TOMORROW_API_KEY=
OPENWEATHERMAP_API_KEY=

# EUMETSAT satellite WMS (MSG/MTG layers)
EUMETSAT_CONSUMER_KEY=
EUMETSAT_CONSUMER_SECRET=

# Optional lightning layer
BLITZORTUNG_TOKEN=

# Rate limiting for /api/* (required before a public/serverless deployment —
# without these, src/proxy.ts skips rate limiting entirely). Free tier at
# upstash.com; create a Redis database and copy its REST credentials.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
